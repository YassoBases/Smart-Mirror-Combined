  height: clamp(1.8rem, 5.5vmin, 2.3rem);
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.07);
  color: rgba(255, 255, 255, 0.65);
  cursor: pointer;
  transition: background 0.18s ease, transform 0.14s ease, color 0.18s ease, border-color 0.18s ease;
