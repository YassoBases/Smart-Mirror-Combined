.sg-btn:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(255, 255, 255, 0.20);
  color: rgba(255, 255, 255, 0.95);
  transform: scale(1.06);
}

.sg-btn:active:not(:disabled) {
  transform: scale(0.95);
}

.sg-btn:disabled {
  opacity: 0.30;
