/* ── Glass card base ──────────────────────────────────────────────────────── */

.sg-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: clamp(0.7rem, 2vmin, 1.1rem) clamp(0.65rem, 1.8vmin, 1rem);
  gap: clamp(0.35rem, 1vmin, 0.6rem);
  box-sizing: border-box;
  overflow: hidden;

  /* Glass effect */
  background: rgba(255, 255, 255, 0.055);
  backdrop-filter: blur(28px) saturate(1.5);
  -webkit-backdrop-filter: blur(28px) saturate(1.5);
  border: 1px solid rgba(255, 255, 255, 0.10);
  border-radius: 1.5rem;

  /* Depth shadow */
  box-shadow:
    0 28px 56px rgba(0, 0, 0, 0.55),
    inset 0 1px 0 rgba(255, 255, 255, 0.10),
    inset 0 0 0 1px rgba(255, 255, 255, 0.04);

  color: #edf2f7;
  font-family: 'Helvetica Neue', Arial, sans-serif;
}

/* Subtle inner top-edge highlight (glass rim light) */
.sg-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 10%;
  width: 80%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.22), transparent);
  pointer-events: none;
}

/* ── Fullscreen toggle button ─────────────────────────────────────────────── */

.sg-fullscreen-btn {
  position: absolute;
  top: 0.9rem;
  right: 0.9rem;
  z-index: 10;
  width: 2rem;
  height: 2rem;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.10);
  background: rgba(255, 255, 255, 0.07);
  color: rgba(255, 255, 255, 0.45);
  display: grid;
  place-items: center;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.25s ease, background 0.2s ease, color 0.2s ease;
}

.sg-fullscreen-btn.is-visible {
  opacity: 1;
}

.sg-fullscreen-btn:hover {
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.85);
}

/* ── Album art ───────────────────────────────────────────────────────────── */

.sg-art-wrap {
  width: clamp(72px, 58%, 140px);
  aspect-ratio: 1 / 1;
  /* Thin glowing frame */
  padding: 2px;
  border-radius: 0.8rem;
  background: rgba(255, 255, 255, 0.07);
