<file path="src/index.css">
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Orbitron:wght@400;500;600&family=Playfair+Display:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

@keyframes welcomeBar {
  from { width: 0; }
  to   { width: 220px; }
}

@keyframes welcomeFadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes welcomeSubtitle {
  from { opacity: 0; transform: translateY(12px); letter-spacing: 0.15em; }
  to   { opacity: 0.5; transform: translateY(0);  letter-spacing: 0.35em; }
}

@keyframes welcomeGlow {
  0%   { text-shadow: 0 0 0px var(--mirror-accent-color); }
  60%  { text-shadow: 0 0 40px var(--mirror-accent-color), 0 0 80px var(--mirror-accent-soft); }
  100% { text-shadow: 0 0 20px var(--mirror-accent-color), 0 0 40px var(--mirror-accent-soft); }
}

:root {
  --mirror-accent-color: #38bdf8;
  --mirror-accent-soft: rgba(125, 211, 252, 0.4);
  --mirror-font-family: 'DM Sans', 'Inter', 'Segoe UI', sans-serif;
  --mirror-widget-border: 1px solid rgba(255, 255, 255, 0.18);
  --mirror-widget-shadow: 0 22px 45px rgba(56, 189, 248, 0.22), 0 0 25px rgba(56, 189, 248, 0.35);
  --mirror-widget-shadow-strong: 0 0 32px rgba(56, 189, 248, 0.45);
  --mirror-widget-radius: 18px;
}

body {
  margin: 0;
  font-family: var(--mirror-font-family), -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
    'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',
    sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background-color: #000000;
  color: white;
}

* {
  box-sizing: border-box;
}

/* Custom scrollbar for dark theme */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.1);
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.5);
}

/* Draggable app styles */
.draggable-app {
  position: absolute;
  cursor: move;
  user-select: none;
}

.draggable-app:hover {
  z-index: 1000;
}

.resize-handle {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48px;
  height: 48px;
  cursor: se-resize;
  z-index: 10;
  background: linear-gradient(-45deg, transparent 0%, transparent 35%, var(--mirror-accent-color) 35%, var(--mirror-accent-color) 42%, transparent 42%, transparent 58%, var(--mirror-accent-color) 58%, var(--mirror-accent-color) 65%, transparent 65%);
}

.hotword-overlay-circle {
  position: relative;
  width: 80vmin;
  height: 80vmin;
  border-radius: 9999px;
  --pulse-scale: 0.95;
  --pulse-outer-alpha: 0.35;
  --pulse-inner-alpha: 0.25;
  --pulse-glow-alpha: 0.6;
  --pulse-ring-opacity: 0.9;
  background: radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.35), rgba(59, 130, 246, 0.18) 40%, rgba(59, 130, 246, 0.08) 70%, rgba(59, 130, 246, 0));
  transform: scale(var(--pulse-scale));
  box-shadow:
    0 40px 120px rgba(59, 130, 246, var(--pulse-outer-alpha)),
    inset 0 0 60px rgba(255, 255, 255, var(--pulse-inner-alpha)),
    0 0 40px rgba(59, 130, 246, var(--pulse-glow-alpha));
  transition: transform 120ms ease-out, box-shadow 180ms ease-out;
  backdrop-filter: blur(4px);
  will-change: transform;
}

.hotword-overlay-circle::before {
  content: '';
  position: absolute;
  inset: 12%;
  border-radius: inherit;
  border: 2px solid rgba(255, 255, 255, 0.45);
  box-shadow:
    inset 0 0 35px rgba(255, 255, 255, 0.35),
    0 0 25px rgba(59, 130, 246, 0.4);
  opacity: var(--pulse-ring-opacity);
  transition: opacity 180ms ease-out;
}

.wake-circle-wrapper {
  position: absolute;
  pointer-events: none;
  transform: translate(-50%, -50%);
  transition: opacity 150ms ease-out;
}

.wake-circle-core {
  position: absolute;
  inset: 0;
  border-radius: 9999px;
  background: radial-gradient(circle at 35% 35%, rgba(191, 219, 254, 0.95), rgba(59, 130, 246, 0.35), rgba(59, 130, 246, 0.05));
  animation: wake-circle-pulse 1.15s ease-in-out infinite;
  box-shadow: 0 0 70px rgba(59, 130, 246, 0.6);
}

.wake-circle-ring {
  position: absolute;
  inset: 0;
  border-radius: 9999px;
  border: 2px solid rgba(191, 219, 254, 0.65);
  animation: wake-circle-ring 1.35s ease-out infinite;
}

.wake-circle-ring--delayed {
  animation-delay: 0.4s;
  opacity: 0.75;
}

@keyframes wake-circle-pulse {
  0% {
    transform: scale(0.92);
    opacity: 0.85;
  }
  50% {
    transform: scale(1.05);
    opacity: 1;
  }
  100% {
    transform: scale(0.92);
    opacity: 0.85;
  }
}

@keyframes wake-circle-ring {
  0% {
    transform: scale(0.85);
    opacity: 0.8;
  }
