PORT=3000
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRES_IN=7d

# LAN IP override for the pairing QR — set one of these on multi-NIC / VPN hosts
# where auto-detection picks the wrong interface (Docker bridge, VPN, etc.).
# MIRROR_LAN_IP=192.168.1.100          # hard-code the exact IP to advertise
# MIRROR_LAN_IFACE=eth0                # pin to an interface name; IP is read dynamically

# Google OAuth — get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# ── Wardrobe feature ──────────────────────────────────────────────────────────
# AI orchestration (Phase 3). Leave blank to disable a feature gracefully.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
REPLICATE_API_TOKEN=
REPLICATE_VTON_MODEL=
# Public origin Replicate uses to fetch body/garment images for VTON (e.g. an
# ngrok https URL: `ngrok http 3000` -> https://<subdomain>.ngrok-free.app).
# Leave blank for local-only setups (VTON won't run; render returns the body photo).
PUBLIC_BASE_URL=
OWM_API_KEY=
# Default coordinates for the weather/context route when a profile has no location.
HOME_LAT=
HOME_LNG=
# Fine-tuned BLIP-2 captioner endpoint (Phase 5). Unset -> stub attribute fallback.
BLIP2_ENDPOINT_URL=
BLIP2_ENDPOINT_TOKEN=
# Python sidecars (Phase 4). In docker-compose these resolve by service name.
BG_REMOVER_URL=http://bg_remover:8001
PREF_RANKER_URL=http://pref_ranker:8002
